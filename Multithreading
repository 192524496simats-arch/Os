#include <stdio.h>
#include <pthread.h>

void *display(void *arg)
{
    printf("Thread is executing\n");
    return NULL;
}

int main()
{
    pthread_t t1, t2;

    pthread_create(&t1, NULL, display, NULL);
    pthread_create(&t2, NULL, display, NULL);

    pthread_join(t1, NULL);
    pthread_join(t2, NULL);

    printf("Threads completed\n");

    return 0;
}
