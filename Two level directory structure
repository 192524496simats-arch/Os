#include <stdio.h>

struct directory
{
    char user[20];
    char file[20];
};

int main()
{
    struct directory d[20];
    int n, i;

    printf("Enter number of files: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Enter User Name: ");
        scanf("%s", d[i].user);

        printf("Enter File Name: ");
        scanf("%s", d[i].file);
    }

    printf("\nTwo Level Directory Structure\n");

    printf("User\t\tFile\n");

    for(i = 0; i < n; i++)
        printf("%s\t\t%s\n", d[i].user, d[i].file);

    return 0;
}
