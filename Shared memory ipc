#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main() {
    key_t key = 1234;
    int shmid;
    char *str;

    shmid = shmget(key, 1024, 0666 | IPC_CREAT);

    str = (char*) shmat(shmid, NULL, 0);

    printf("Write Data: ");
    gets(str);

    printf("Data Written: %s\n", str);

    shmdt(str);

    return 0;
}
