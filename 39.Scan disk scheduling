#include <stdio.h>
#include <stdlib.h>

int main() {
    int req[100], n, head, disk_size;
    int i, j, temp, seek = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter requests:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &disk_size);

    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(req[i] > req[j]) {
                temp = req[i];
                req[i] = req[j];
                req[j] = temp;
            }
        }
    }

    int pos;
    for(i = 0; i < n; i++) {
        if(req[i] >= head) {
            pos = i;
            break;
        }
    }

    for(i = pos; i < n; i++) {
        seek += abs(head - req[i]);
        head = req[i];
    }

    seek += abs(head - (disk_size - 1));
    head = disk_size - 1;

    for(i = pos - 1; i >= 0; i--) {
        seek += abs(head - req[i]);
        head = req[i];
    }

    printf("Total Seek Time = %d\n", seek);

    return 0;
}
