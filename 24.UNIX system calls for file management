#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int fd;
    char data[] = "Operating System Lab";

    fd = open("sample.txt", O_CREAT | O_WRONLY, 0644);

    write(fd, data, sizeof(data));

    close(fd);

    printf("File created and data written successfully.\n");

    return 0;
}
